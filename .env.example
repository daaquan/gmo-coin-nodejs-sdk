# Copy to .env and fill values. Note: this repo does not auto-load .env.
# Use shell exports or a dotenv loader when running examples.

# Required for Forex REST/WS auth (FX API)
FX_API_KEY=your_api_key
FX_API_SECRET=your_api_secret

# Optional: For Cryptocurrency API auth
CRYPTO_API_KEY=your_crypto_api_key
CRYPTO_API_SECRET=your_crypto_api_secret

# Optional: use a pre-created WS token instead of calling /v1/ws-auth
WS_TOKEN=

# Optional: control order placement in examples/private-rest.ts
# By default, the example DOES NOT place orders.
# Enable exactly one of the following to place and then cancel an order.
PLACE_LIMIT=
PLACE_SPEED=

# Order parameters (used by the example when placement is enabled)
ORDER_SYMBOL=USD_JPY
ORDER_SIDE=BUY
ORDER_SIZE=1000
ORDER_LIMIT_PRICE=

# Microservice settings
PORT=3000
# Optional simple auth for the microservice (HTTP Authorization: Bearer <token>)
SERVICE_AUTH_TOKEN=

# Auth via JWT (JWKS) instead of shared token
# SERVICE_AUTH_MODE=jwt
# JWKS_URL=https://your-domain/.well-known/jwks.json
# JWT_ISSUER=your-issuer
# JWT_AUDIENCE=your-audience

# Redis for distributed rate limiting + idempotency
# e.g. redis://localhost:6379
REDIS_URL=
