{
  "name": "fx-sdk",
  "version": "0.1.0",
  "description": "GMO Coin Forex (FX) Private API SDK (Node.js/TypeScript)",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "examples:rest": "npm run build && node dist/examples/private-rest.js",
    "examples:ws": "npm run build && node dist/examples/private-ws.js",
    "start:service": "npm run build && node dist/service/server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "jose": "^5.8.0",
    "pino": "^9.4.0",
    "ws": "^8.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4"
  }
}
